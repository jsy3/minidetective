# 포트 (기본 4000)
PORT=4000

# 토스 API Base (변경 불필요)
AUTH_API_BASE=https://apps-in-toss-api.toss.im/api-partner/v1/apps-in-toss/user/oauth2
# 이 서버의 generate-token / refresh-token / login-me 는 파트너 mTLS 로만 인증합니다(CLIENT_ID·SECRET 미사용).

# mTLS 인증서 (앱인토스 콘솔에서 발급)
CLIENT_CERT_PATH=cert/mock_public.crt
CLIENT_KEY_PATH=cert/mock_private.key
# Vercel 등 파일 없이 배포: PEM 파일 바이너리를 Base64 한 줄로 (openssl base64 -A 또는 PowerShell ReadAllBytes)
# CLIENT_CERT_BASE64=
# CLIENT_KEY_BASE64=

# 사용자 정보 복호화 (콘솔 이메일로 수신한 복호화 키, AAD) — login-me 복호화·프로덕션에서도 Vercel에 동일 키 설정
DECRYPTION_KEY_BASE64=your_base64_key
AAD_STRING=TOSS
