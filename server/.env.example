# 포트 (기본 4000)
PORT=4000

# 토스 API Base (변경 불필요)
AUTH_API_BASE=https://apps-in-toss-api.toss.im/api-partner/v1/apps-in-toss/user/oauth2
PROMOTION_API_BASE=https://apps-in-toss-api.toss.im/api-partner/v1/apps-in-toss/promotion/execute-promotion
PROMOTION_CODE=01KHK7GMRDY7A4BVVP1HRN4XY8
# 지급 금액은 서버에서 1~5 포인트 사이로 랜덤 결정

# mTLS 인증서 (앱인토스 콘솔에서 발급)
CLIENT_CERT_PATH=cert/mock_public.crt
CLIENT_KEY_PATH=cert/mock_private.key

# 사용자 정보 복호화 (콘솔 이메일로 수신한 복호화 키, AAD)
DECRYPTION_KEY_BASE64=your_base64_key
AAD_STRING=TOSS
